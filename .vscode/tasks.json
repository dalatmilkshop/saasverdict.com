		{
			"label": "verify-mlx-image-links",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$root=(Get-Location).Path; $pages=Get-ChildItem '.\\guides\\mlx-api-hub' -Recurse -File -Filter index.html; $missing=[System.Collections.Generic.List[string]]::new(); $totalRefs=0; foreach($p in $pages){ $html=Get-Content -Raw -LiteralPath $p.FullName; $ms=[regex]::Matches($html,'src=\"(/assets/img/guides/mlx-api-hub/[^\"]+)\"'); foreach($m in $ms){ $totalRefs++; $rel=$m.Groups[1].Value.TrimStart('/'); $abs=Join-Path $root ($rel -replace '/','\\'); if(-not (Test-Path -LiteralPath $abs)){ $missing.Add(($p.FullName + ' => ' + $rel)); } } }; Write-Output ('pages=' + $pages.Count); Write-Output ('img_refs=' + $totalRefs); Write-Output ('missing=' + $missing.Count); if($missing.Count -gt 0){ $missing | Select-Object -First 20 | ForEach-Object { Write-Output $_ } }"
			],
			"isBackground": false
		},
